---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Password Generator — Generate Strong Secure Passwords Online | DevSuite"
  description="Free online password generator. Create cryptographically strong, random passwords with customizable length, character types, and strength meter. No data stored or transmitted."
  canonicalPath="/password-generator"

  toolName="Password Generator"
  toolDescription="Create cryptographically strong, random passwords with a strength meter."
>
  <style>
    .display-box {
      background: var(--color-surface);
      border: 2px dashed var(--color-border);
      border-radius: 8px;
      padding: 2rem 1rem;
      text-align: center;
      margin-bottom: 1.5rem;
      position: relative;
    }
    .pw-text {
      font-family: monospace;
      font-size: 2.25rem;
      font-weight: 700;
      color: var(--color-text);
      word-break: break-all;
      min-height: 3.5rem;
    }
    .strength-meter {
      height: 6px;
      background: var(--color-surface-hover);
      border-radius: 3px;
      margin-top: 1rem;
      overflow: hidden;
      display: flex;
    }
    .strength-fill {
      height: 100%;
      width: 0%;
      transition: width 0.3s ease, background-color 0.3s ease;
    }
    .strength-info {
      display: flex;
      justify-content: space-between;
      font-size: 0.875rem;
      color: var(--color-text-muted);
      margin-top: 0.5rem;
    }
    .controls-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      background: var(--color-surface);
      padding: 1.5rem;
      border-radius: 8px;
      border: 1px solid var(--color-border);
      margin-bottom: 2rem;
    }
    @media (max-width: 640px) {
      .controls-grid { grid-template-columns: 1fr; }
    }
    .bulk-list {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      padding: 1rem;
      max-height: 200px;
      overflow-y: auto;
      font-family: monospace;
      white-space: pre-wrap;
    }
    .destroyed-overlay {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.85);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      font-size: 1.25rem;
      border-radius: 8px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
      z-index: 10;
    }
    .destroyed-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }
  </style>

  <div class="ad-layout">
    <aside class="ad-sidebar left-ad">
      <ins class="adsbygoogle"
     style="display:block"
     data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
     data-ad-slot="SIDEBAR_SLOT_ID"
     data-ad-format="auto"
     data-full-width-responsive="true"></ins>
<script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>

    <div class="ad-workspace">
      <header class="workspace-header">
        <h1>Password Generator</h1>
        <p>Generate strong, cryptographically random passwords instantly. Customize length and character types. Your passwords are generated locally and never stored or transmitted.</p>
      </header>

      <section class="workspace-section">
        <!-- Display Box -->
        <div class="display-box">
          <div id="pw-display" class="pw-text">Click generate to start</div>
          
          <div class="strength-meter">
            <div id="strength-fill" class="strength-fill"></div>
          </div>
          <div class="strength-info">
            <span id="strength-label">Strength: --</span>
            <span id="crack-time">Crack time: --</span>
          </div>

          <div id="destroyed-overlay" class="destroyed-overlay">
            PASSWORD DESTROYED FOR SECURITY
          </div>
        </div>

        <!-- Primary Actions -->
        <div style="display: flex; gap: 1rem; justify-content: center; margin-bottom: 2rem; flex-wrap: wrap;">
          <button id="btn-generate" class="btn btn-primary" style="font-size: 1.125rem; padding: 0.75rem 2rem;">Generate & Copy</button>
          <button id="btn-copy" class="btn btn-accent" style="font-size: 1.125rem; padding: 0.75rem 2rem;">Copy Password</button>
        </div>

        <!-- Controls -->
        <div class="controls-grid">
          <div>
            <label class="section-label" style="display: flex; justify-content: space-between;">
              <span>Password Length</span>
              <span id="len-val">16</span>
            </label>
            <div style="display: flex; align-items: center; gap: 1rem;">
              <input type="range" id="len-slider" min="4" max="128" value="16" style="flex: 1; cursor: pointer;" />
              <input type="number" id="len-input" class="input" min="4" max="128" value="16" style="width: 70px; padding: 0.25rem;" />
            </div>
            
            <label class="section-label" style="margin-top: 1.5rem;">Security Options</label>
            <div style="display: flex; flex-direction: column; gap: 0.5rem; color: var(--color-text);">
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                <input type="checkbox" id="chk-exclude-ambig" /> Exclude Ambiguous (0, O, l, 1, I)
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                <input type="checkbox" id="chk-exclude-similar" /> Exclude Similar ({}, [], (), /)
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: #e74c3c; margin-top: 0.5rem;">
                <input type="checkbox" id="chk-auto-destroy" checked /> Auto-Destroy after 30s
              </label>
            </div>
          </div>

          <div>
            <label class="section-label">Character Types</label>
            <div style="display: flex; flex-direction: column; gap: 0.75rem; color: var(--color-text);">
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                <input type="checkbox" id="chk-upper" checked /> Uppercase (A-Z)
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                <input type="checkbox" id="chk-lower" checked /> Lowercase (a-z)
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                <input type="checkbox" id="chk-nums" checked /> Numbers (0-9)
              </label>
              <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                <input type="checkbox" id="chk-syms" checked /> Symbols (!@#$%^&*...)
              </label>
            </div>
          </div>
        </div>

        <!-- Bulk Generation -->
        <div style="background: var(--color-surface); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--color-border);">
          <label class="section-label">Bulk Generation</label>
          <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem; flex-wrap: wrap;">
            <span>Quantity:</span>
            <input type="number" id="bulk-amount" class="input" min="1" max="50" value="5" style="width: 80px;" />
            <button id="btn-bulk-gen" class="btn btn-primary">Generate Multiple</button>
            <button id="btn-bulk-copy" class="btn btn-accent">Copy All</button>
          </div>
          <div id="bulk-list" class="bulk-list"></div>
        </div>
      </section>

      <!-- SEO Content Section -->
      <section class="prose" style="margin-top: 3rem;">
        <h2>Why Strong Passwords Matter</h2>
        <p>
          In an era of relentless data breaches, using a <strong>secure password generator</strong> is no longer optional. When you generate a strong password online, you protect yourself against credential stuffing, dictionary attacks, and brute force techniques.
        </p>
        <h3>How We Calculate Strength</h3>
        <p>
          Password strength is primarily determined by <em>entropy</em>, which is calculated based on the length of the password and the size of the character pool (charset). We calculate entropy using the formula: <code>log2(charset_size ^ length)</code>. We then estimate the crack time assuming an attacker can make 10 billion guesses per second (a standard baseline for modern GPU clusters).
        </p>
        <h3>True Randomness via Web Crypto API</h3>
        <p>
          Many basic generators use <code>Math.random()</code>, which is a pseudo-random number generator and is not cryptographically secure. Our <strong>random password generator</strong> exclusively uses <code>crypto.getRandomValues()</code> provided by modern browsers to ensure cryptographically secure entropy. Your passwords are generated 100% locally on your device.
        </p>
        <h3>Common Password Mistakes</h3>
        <ul>
          <li><strong>Too Short:</strong> 8 characters is no longer enough. Aim for at least 16 characters.</li>
          <li><strong>Reusing Passwords:</strong> If one site gets breached, attackers will try that password everywhere. Use a unique password for every site.</li>
          <li><strong>Predictable Substitutions:</strong> Using "P@ssw0rd" instead of "Password" is easily defeated by modern cracking dictionaries.</li>
        </ul>
        <p>
          We highly recommend using this tool in conjunction with a reputable password manager. Generate complex, impossible-to-memorize strings, store them securely in your vault, and never worry about compromised accounts again.
        </p>
      </section>
    
      <!-- MASSIVE SEO PROSE SECTION -->
      <section class="prose" style="margin-top: 4rem; border-top: 1px solid var(--color-border); padding-top: 2rem;">
        <h2>The Ultimate Strong Password Generator</h2>
        <p>In today's digital landscape, the security of your personal data, bank accounts, and corporate infrastructure relies entirely on the strength of your passwords. Reusing passwords or using easily guessable words is the leading cause of account takeovers. Our <strong>free online password generator</strong> solves this by instantly creating highly secure, cryptographically random passwords. Designed for maximum security and ease of use, this <strong>random password creator</strong> ensures you have ironclad protection against brute-force and dictionary attacks.</p>

        <h3>What Makes a Password Strong?</h3>
        <p>A strong password relies on two primary factors: Length and Complexity (Entropy). An <strong>advanced password generator</strong> manipulates these factors to create uncrackable strings.</p>
        <ul>
          <li><strong>Length:</strong> Length is the most critical factor. A 6-character password with symbols can be cracked in seconds. A 16-character password using only lowercase letters could take centuries. We strongly recommend setting the length slider to at least 16 characters for critical accounts.</li>
          <li><strong>Complexity:</strong> Mixing different character sets exponentially increases the number of possible combinations. A robust password should include uppercase letters (A-Z), lowercase letters (a-z), numbers (0-9), and special symbols (!@#$%^&*).</li>
          <li><strong>Unpredictability:</strong> Humans are terrible at creating random patterns. We tend to capitalize the first letter, put a number at the end, and use a common symbol (e.g., Password123!). Hackers know this. Our tool removes human predictability by utilizing true mathematical randomness.</li>
        </ul>

        <h3>Cryptographically Secure Randomness</h3>
        <p>Not all randomness is created equal. Many cheap <strong>password makers</strong> use standard pseudo-random number generators (like <code>Math.random()</code> in JavaScript). These algorithms are predictable; if a hacker figures out the "seed" state of the generator, they can predict every password it generates. This is a massive security flaw.</p>
        <p>Our <strong>secure password generator</strong> strictly utilizes the <code>Web Crypto API</code> (specifically <code>crypto.getRandomValues()</code>). This accesses your device's hardware-based random number generator, pulling entropy from physical hardware noise. This guarantees that the passwords generated are cryptographically secure and completely unpredictable, meeting the stringent standards required by enterprise security and government regulations.</p>

        <h3>Client-Side Generation: Total Privacy</h3>
        <p>The cardinal rule of cybersecurity is never to transmit a plain-text password over the internet unless absolutely necessary. When you use an online generator that creates the password on a remote server, you have to trust that the server isn't logging it. With DevSuite's <strong>browser-based password tool</strong>, absolute privacy is guaranteed. The generation script runs 100% locally on your machine. The password is created in your browser's memory, displayed on your screen, and copied to your clipboard—it never traverses a network or touches a server.</p>

        <h3>Understanding the Password Strength Meter</h3>
        <p>To help you understand the security of your generated string, our tool features an integrated <strong>password strength checker</strong>. This algorithm analyzes the length and complexity of the generated text to estimate its entropy (measured in bits). Passwords with low entropy are flagged as Weak or Fair, while long, complex passwords that would take supercomputers millennia to crack are flagged as Strong or Excellent. Always aim for the green "Strong" indicator before using a password for sensitive accounts like email, banking, or crypto wallets.</p>
      </section>
    </div>

    <aside class="ad-sidebar right-ad">
      <ins class="adsbygoogle"
     style="display:block"
     data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
     data-ad-slot="SIDEBAR_SLOT_ID"
     data-ad-format="auto"
     data-full-width-responsive="true"></ins>
<script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>
  </div>
</MainLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Elements
    const pwDisplay = document.getElementById('pw-display');
    const strengthFill = document.getElementById('strength-fill');
    const strengthLabel = document.getElementById('strength-label');
    const crackTime = document.getElementById('crack-time');
    const destroyedOverlay = document.getElementById('destroyed-overlay');
    
    const btnGenerate = document.getElementById('btn-generate');
    const btnCopy = document.getElementById('btn-copy');
    
    const lenSlider = document.getElementById('len-slider');
    const lenInput = document.getElementById('len-input');
    const lenVal = document.getElementById('len-val');
    
    const chkUpper = document.getElementById('chk-upper');
    const chkLower = document.getElementById('chk-lower');
    const chkNums = document.getElementById('chk-nums');
    const chkSyms = document.getElementById('chk-syms');
    const chkAmbig = document.getElementById('chk-exclude-ambig');
    const chkSimilar = document.getElementById('chk-exclude-similar');
    const chkAutoDestroy = document.getElementById('chk-auto-destroy');
    
    const bulkAmount = document.getElementById('bulk-amount');
    const btnBulkGen = document.getElementById('btn-bulk-gen');
    const btnBulkCopy = document.getElementById('btn-bulk-copy');
    const bulkList = document.getElementById('bulk-list');

    // Charsets
    const UPPER = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    const LOWER = "abcdefghijklmnopqrstuvwxyz";
    const NUMS = "0123456789";
    const SYMS = "!@#$%^&*()_+-=[]{}|;:',.<>?/";
    const AMBIG = "0Ol1I";
    const SIMILAR = "{}[]()/";

    let destroyTimeout = null;

    function getCharset() {
      let chars = "";
      if (chkUpper.checked) chars += UPPER;
      if (chkLower.checked) chars += LOWER;
      if (chkNums.checked) chars += NUMS;
      if (chkSyms.checked) chars += SYMS;

      if (chars === "") return LOWER; // fallback

      if (chkAmbig.checked) {
        chars = chars.split('').filter(c => !AMBIG.includes(c)).join('');
      }
      if (chkSimilar.checked) {
        chars = chars.split('').filter(c => !SIMILAR.includes(c)).join('');
      }

      return chars;
    }

    function generateSecurePassword(length, charset) {
      if (charset.length === 0) return "";
      const array = new Uint32Array(length);
      window.crypto.getRandomValues(array);
      let password = "";
      for (let i = 0; i < length; i++) {
        password += charset[array[i] % charset.length];
      }
      return password;
    }

    function calculateStrength(length, charsetSize) {
      // Entropy = L * log2(R)
      const entropy = length * Math.log2(charsetSize);
      
      // Guesses = 2^(entropy - 1) on average. 
      // Speed = 10 billion / sec (10^10)
      const guesses = Math.pow(2, entropy - 1);
      const seconds = guesses / 10000000000;

      let timeStr = "";
      if (seconds < 1) timeStr = "Instant";
      else if (seconds < 60) timeStr = `${Math.round(seconds)} seconds`;
      else if (seconds < 3600) timeStr = `${Math.round(seconds/60)} minutes`;
      else if (seconds < 86400) timeStr = `${Math.round(seconds/3600)} hours`;
      else if (seconds < 31536000) timeStr = `${Math.round(seconds/86400)} days`;
      else if (seconds < 3153600000) timeStr = `${Math.round(seconds/31536000)} years`;
      else timeStr = "Centuries+";

      let score = 0; // 0 to 3
      if (entropy < 40) score = 0; // Weak
      else if (entropy < 60) score = 1; // Fair
      else if (entropy < 80) score = 2; // Strong
      else score = 3; // Very Strong

      return { score, timeStr, entropy };
    }

    function updateMeter(strength) {
      const colors = ["#e74c3c", "#f1c40f", "#2ecc71", "#27ae60"];
      const labels = ["Weak", "Fair", "Strong", "Very Strong"];
      const widths = ["25%", "50%", "75%", "100%"];

      strengthFill.style.width = widths[strength.score];
      strengthFill.style.backgroundColor = colors[strength.score];
      
      strengthLabel.textContent = `Strength: ${labels[strength.score]}`;
      strengthLabel.style.color = colors[strength.score];
      
      crackTime.textContent = `Crack time: ${strength.timeStr}`;
    }

    function triggerDestroyTimer() {
      if (destroyTimeout) clearTimeout(destroyTimeout);
      destroyedOverlay.classList.remove('active');
      
      if (chkAutoDestroy.checked) {
        destroyTimeout = setTimeout(() => {
          pwDisplay.textContent = "";
          bulkList.textContent = "";
          destroyedOverlay.classList.add('active');
          
          // Best effort to clear clipboard
          try {
             navigator.clipboard.writeText(" ");
          } catch(e) {}
        }, 30000); // 30 seconds
      }
    }

    function doGenerate(autoCopy = false) {
      const len = parseInt(lenSlider.value);
      const charset = getCharset();
      
      if (charset.length === 0) {
         if(typeof window.showToast === 'function') window.showToast('Please select at least one character type.');
         return;
      }

      const pw = generateSecurePassword(len, charset);
      pwDisplay.textContent = pw;
      
      const strength = calculateStrength(len, charset.length);
      updateMeter(strength);

      triggerDestroyTimer();

      if (autoCopy) {
        navigator.clipboard.writeText(pw).then(() => {
          if(typeof window.showToast === 'function') window.showToast('Generated & Copied!');
        });
      }
    }

    // Events
    btnGenerate.addEventListener('click', () => doGenerate(true));
    
    btnCopy.addEventListener('click', () => {
      const pw = pwDisplay.textContent;
      if (pw && !destroyedOverlay.classList.contains('active')) {
        navigator.clipboard.writeText(pw).then(() => {
          if(typeof window.showToast === 'function') window.showToast('Copied to clipboard!');
        });
      }
    });

    // Sync sliders/inputs
    lenSlider.addEventListener('input', (e) => {
      lenInput.value = e.target.value;
      lenVal.textContent = e.target.value;
      doGenerate(false);
    });
    lenInput.addEventListener('change', (e) => {
      let v = parseInt(e.target.value);
      if (v < 4) v = 4;
      if (v > 128) v = 128;
      e.target.value = v;
      lenSlider.value = v;
      lenVal.textContent = v;
      doGenerate(false);
    });

    [chkUpper, chkLower, chkNums, chkSyms, chkAmbig, chkSimilar].forEach(el => {
      el.addEventListener('change', () => doGenerate(false));
    });

    chkAutoDestroy.addEventListener('change', () => {
       if (!chkAutoDestroy.checked) {
          if(destroyTimeout) clearTimeout(destroyTimeout);
          destroyedOverlay.classList.remove('active');
       } else {
          triggerDestroyTimer();
       }
    });

    // Bulk
    btnBulkGen.addEventListener('click', () => {
       const len = parseInt(lenSlider.value);
       const charset = getCharset();
       let amt = parseInt(bulkAmount.value);
       if (isNaN(amt) || amt < 1) amt = 1;
       if (amt > 50) amt = 50;
       
       if (charset.length === 0) return;

       let out = [];
       for (let i = 0; i < amt; i++) {
         out.push(generateSecurePassword(len, charset));
       }
       bulkList.textContent = out.join('\n');
       
       triggerDestroyTimer();
    });

    btnBulkCopy.addEventListener('click', () => {
      const txt = bulkList.textContent;
      if (txt && !destroyedOverlay.classList.contains('active')) {
        navigator.clipboard.writeText(txt).then(() => {
          if(typeof window.showToast === 'function') window.showToast('Copied all passwords!');
        });
      }
    });

    // Initial generate (no auto copy on page load)
    doGenerate(false);
  });
</script>
