  document.addEventListener('DOMContentLoaded', () => {
    const textInput = document.getElementById('text-input');
    const optUppercase = document.getElementById('opt-uppercase');
    const btnClear = document.getElementById('btn-clear');
    
    const outMd5 = document.getElementById('out-md5');
    const outSha1 = document.getElementById('out-sha1');
    const outSha256 = document.getElementById('out-sha256');
    const outSha512 = document.getElementById('out-sha512');

    async function hashWebCrypto(algorithm, text) {
      if (!text) {
          // Precomputed empty string hashes
          if (algorithm === 'SHA-1') return 'da39a3ee5e6b4b0d3255bfef95601890afd80709';
          if (algorithm === 'SHA-256') return 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855';
          if (algorithm === 'SHA-512') return 'cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e';
      }
      const msgUint8 = new TextEncoder().encode(text);
      const hashBuffer = await crypto.subtle.digest(algorithm, msgUint8);
      const hashArray = Array.from(new Uint8Array(hashBuffer));
      const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
      return hashHex;
    }

    async function updateHashes() {
      const text = textInput.value;
      const isUpper = optUppercase.checked;

      // MD5
      let md5Hash = md5(text);
      outMd5.textContent = isUpper ? md5Hash.toUpperCase() : md5Hash;

      // Web Crypto API
      if (crypto && crypto.subtle) {
        try {
          let sha1 = await hashWebCrypto('SHA-1', text);
          outSha1.textContent = isUpper ? sha1.toUpperCase() : sha1;

          let sha256 = await hashWebCrypto('SHA-256', text);
          outSha256.textContent = isUpper ? sha256.toUpperCase() : sha256;

          let sha512 = await hashWebCrypto('SHA-512', text);
          outSha512.textContent = isUpper ? sha512.toUpperCase() : sha512;
        } catch (e) {
          console.error("Crypto API error:", e);
        }
      } else {
        outSha1.textContent = "Web Crypto API not supported in this browser";
        outSha256.textContent = "Web Crypto API not supported in this browser";
        outSha512.textContent = "Web Crypto API not supported in this browser";
      }
    }

    textInput.addEventListener('input', updateHashes);
    optUppercase.addEventListener('change', updateHashes);

    btnClear.addEventListener('click', () => {
      textInput.value = '';
      updateHashes();
    });

    document.querySelectorAll('.btn-copy').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const targetId = e.target.getAttribute('data-target');
        const el = document.getElementById(targetId);
        if (el) {
          navigator.clipboard.writeText(el.textContent.trim()).then(() => {
            if (typeof window.showToast === 'function') {
              window.showToast('Copied hash!');
            }
          });
        }
      });
    });

    // Init
    updateHashes();
  });
</script>
