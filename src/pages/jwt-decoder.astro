---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="JWT Decoder — Decode and Inspect JSON Web Tokens Online | DevSuite"
  description="Free online JWT decoder and inspector. Decode JSON Web Tokens to view header, payload, and signature. Check expiration times. No data sent to servers."
  canonicalPath="/jwt-decoder"

  toolName="JWT Decoder"
  toolDescription="Decode JSON Web Tokens and inspect header, payload, and claims locally."
>
  <style>
    .jwt-panel {
      padding: 1rem;
      border-radius: 8px;
      margin-bottom: 1rem;
      border: 1px solid var(--color-border);
    }
    .panel-header {
      background: rgba(52, 152, 219, 0.1);
      border-left: 4px solid #3498db;
    }
    .panel-payload {
      background: rgba(155, 89, 182, 0.1);
      border-left: 4px solid #9b59b6;
    }
    .panel-signature {
      background: rgba(230, 126, 34, 0.1);
      border-left: 4px solid #e67e22;
    }
    .panel-title {
      font-weight: bold;
      margin-bottom: 0.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .panel-title span {
      text-transform: uppercase;
      font-size: 0.875rem;
      letter-spacing: 1px;
    }
    .jwt-output {
      font-family: monospace;
      white-space: pre-wrap;
      word-break: break-all;
      background: var(--color-surface);
      padding: 0.75rem;
      border-radius: 4px;
      margin: 0;
      font-size: 0.875rem;
      color: var(--color-text);
      border: 1px solid var(--color-border);
    }
    .status-indicator {
      display: inline-block;
      padding: 0.5rem 1rem;
      border-radius: 4px;
      font-weight: bold;
      margin-bottom: 1rem;
    }
    .status-valid {
      background: rgba(46, 204, 113, 0.2);
      color: #27ae60;
    }
    .status-invalid {
      background: rgba(231, 76, 60, 0.2);
      color: #c0392b;
    }
    .claims-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }
    .claims-table th, .claims-table td {
      border: 1px solid var(--color-border);
      padding: 0.75rem;
      text-align: left;
    }
    .claims-table th {
      background: var(--color-surface-hover);
      font-weight: 600;
    }
    .tag-valid {
      color: #27ae60;
      font-weight: bold;
    }
    .tag-expired {
      color: #e74c3c;
      font-weight: bold;
    }
  </style>

  <div class="ad-layout">
    <aside class="ad-sidebar left-ad">
      <ins class="adsbygoogle"
     style="display:block"
     data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
     data-ad-slot="SIDEBAR_SLOT_ID"
     data-ad-format="auto"
     data-full-width-responsive="true"></ins>
<script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>

    <div class="ad-workspace">
      <header class="workspace-header">
        <h1>JWT Decoder & Inspector</h1>
        <p>Paste a JSON Web Token below to decode and inspect its header, payload, claims, and expiration status. All decoding happens locally — your tokens never leave your browser.</p>
      </header>

      <section class="workspace-section">
        <div style="margin-bottom: 1.5rem;">
          <label class="section-label" for="jwt-input">JSON Web Token</label>
          <textarea id="jwt-input" class="input" rows="6" placeholder="ey... (paste your JWT here)" style="font-family: monospace;"></textarea>
        </div>

        <div id="status-bar" class="status-indicator" style="display: none;"></div>

        <div id="output-section" style="display: none;">
          <div class="jwt-panel panel-header">
            <div class="panel-title">
              <span style="color: #2980b9;">Header (Algorithm & Token Type)</span>
              <button id="btn-copy-header" class="btn" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">Copy</button>
            </div>
            <pre id="out-header" class="jwt-output"></pre>
          </div>

          <div class="jwt-panel panel-payload">
            <div class="panel-title">
              <span style="color: #8e44ad;">Payload (Data & Claims)</span>
              <button id="btn-copy-payload" class="btn" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">Copy</button>
            </div>
            <pre id="out-payload" class="jwt-output"></pre>
            
            <h3 style="margin-top: 1.5rem; margin-bottom: 0.5rem; font-size: 1.125rem;">Claims Analysis</h3>
            <div style="overflow-x: auto;">
              <table class="claims-table">
                <thead>
                  <tr>
                    <th>Claim</th>
                    <th>Value</th>
                    <th>Description</th>
                  </tr>
                </thead>
                <tbody id="claims-body">
                  <!-- Rendered via JS -->
                </tbody>
              </table>
            </div>
          </div>

          <div class="jwt-panel panel-signature">
            <div class="panel-title">
              <span style="color: #d35400;">Signature</span>
            </div>
            <pre id="out-signature" class="jwt-output"></pre>
          </div>
        </div>
      </section>

      <!-- SEO Content Section -->
      <section class="prose" style="margin-top: 3rem;">
        <h2>What is a JSON Web Token (JWT)?</h2>
        <p>
          A JSON Web Token (JWT) is an open standard (RFC 7519) that defines a compact and self-contained way for securely transmitting information between parties as a JSON object. This information can be verified and trusted because it is digitally signed. By using our <strong>jwt decoder online</strong>, you can instantly inspect the contents of any valid token.
        </p>
        <h3>JWT Structure</h3>
        <p>
          JWTs are composed of three parts separated by dots (<code>.</code>):
        </p>
        <ol>
          <li><strong>Header:</strong> Typically consists of two parts: the type of the token (JWT) and the signing algorithm being used (e.g., HMAC SHA256 or RSA).</li>
          <li><strong>Payload:</strong> Contains the claims. Claims are statements about an entity (typically, the user) and additional data. Using a <strong>jwt payload viewer online</strong> allows developers to debug auth issues quickly.</li>
          <li><strong>Signature:</strong> To create the signature part you have to take the encoded header, the encoded payload, a secret, the algorithm specified in the header, and sign that.</li>
        </ol>
        <h3>Common Claims</h3>
        <ul>
          <li><strong>iss (Issuer):</strong> Identifies the principal that issued the JWT.</li>
          <li><strong>sub (Subject):</strong> Identifies the principal that is the subject of the JWT.</li>
          <li><strong>aud (Audience):</strong> Identifies the recipients that the JWT is intended for.</li>
          <li><strong>exp (Expiration Time):</strong> Identifies the expiration time on or after which the JWT MUST NOT be accepted for processing. Our tool lets you <strong>check jwt expiration online</strong> instantly.</li>
          <li><strong>iat (Issued At):</strong> Identifies the time at which the JWT was issued.</li>
        </ul>
        <h3>Encoding vs. Encryption</h3>
        <p>
          A common misconception is that JWTs are encrypted. They are not! They are merely Base64Url encoded. Anyone who intercepts a JWT can decode and read the payload. Therefore, you should <strong>never put sensitive data</strong> (like passwords or social security numbers) inside a JWT payload.
        </p>
        <p>
          <em>Note: This tool acts as a <strong>jwt inspector</strong> and <strong>jwt parser</strong> to decode tokens. It does not verify the signature, which requires the private or shared secret key.</em>
        </p>
      </section>
    
      <!-- MASSIVE SEO PROSE SECTION -->
      <section class="prose" style="margin-top: 4rem; border-top: 1px solid var(--color-border); padding-top: 2rem;">
        <h2>The Ultimate JWT Decoder and Debugger</h2>
        <p>JSON Web Tokens (JWT) are the modern standard for securing APIs, managing user authentication, and transmitting verified claims across decentralized web applications. However, because JWTs are encoded strings, you cannot simply read their contents. Our <strong>free online JWT decoder</strong> allows developers to instantly parse, decode, and inspect the header and payload of any JSON Web Token. It is an essential <strong>JWT debugging tool</strong> for troubleshooting authentication flows, OAuth integrations, and API authorization issues.</p>

        <h3>What is a JSON Web Token (JWT)?</h3>
        <p>A JWT (defined by RFC 7519) is a compact, URL-safe means of representing claims to be transferred between two parties. The claims in a JWT are encoded as a JSON object that is used as the payload of a JSON Web Signature (JWS) structure or as the plaintext of a JSON Web Encryption (JWE) structure. An <strong>online token decoder</strong> helps developers visualize this data.</p>
        <p>A standard JWT consists of three parts separated by dots (<code>.</code>):</p>
        <ul>
          <li><strong>Header:</strong> Contains metadata about the token, specifically the type of token (JWT) and the cryptographic signing algorithm used (e.g., HS256, RS256).</li>
          <li><strong>Payload (Claims):</strong> Contains the actual data (claims) being transmitted. This usually includes the user's ID, roles, email, and standard registered claims like <code>iat</code> (Issued At) and <code>exp</code> (Expiration Time).</li>
          <li><strong>Signature:</strong> A cryptographic hash generated by combining the encoded header, the encoded payload, and a secret key. This ensures the token has not been altered in transit.</li>
        </ul>

        <h3>How Does a JWT Decoder Work?</h3>
        <p>Many developers mistakenly believe that JWTs are encrypted. <strong>They are not encrypted; they are only Base64Url encoded.</strong> This is a crucial security concept. Anyone who intercepts a standard JWT can use a <strong>JWT parser</strong> like ours to decode the header and payload and read the data inside.</p>
        <p>Our tool splits the token at the dots, takes the first two parts (Header and Payload), and reverses the Base64Url encoding. It then parses the resulting string back into formatted JSON. This allows you to instantly verify if your backend authentication server is embedding the correct user roles and expiration timestamps.</p>

        <h3>Troubleshooting JWT Expiration (exp)</h3>
        <p>One of the most common issues in token-based authentication is dealing with expired tokens. The <code>exp</code> claim inside a JWT payload represents the expiration time as a Unix epoch timestamp (the number of seconds since January 1, 1970). Looking at "1735689600" doesn't tell a human much. Our <strong>JWT epoch converter</strong> automatically detects standard timestamp claims (like <code>exp</code>, <code>iat</code>, and <code>nbf</code>) and translates them into human-readable local dates and times. This allows you to instantly determine if your token has expired and is the cause of your API 401 Unauthorized errors.</p>

        <h3>Absolute Security: Zero-Data Retention</h3>
        <p>JWTs are the keys to the kingdom. Pasting a production JWT (like an access token or an ID token) into a random third-party website is a massive security risk. If a malicious server logs your token, they can impersonate your user and access your APIs. Our <strong>secure client-side JWT decoder</strong> eliminates this risk entirely. The decoding process is executed 100% locally in your browser using JavaScript. No network requests are made. Your token is never transmitted, logged, or saved, making this a safe tool for debugging production tokens.</p>
      </section>
    </div>

    <aside class="ad-sidebar right-ad">
      <ins class="adsbygoogle"
     style="display:block"
     data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
     data-ad-slot="SIDEBAR_SLOT_ID"
     data-ad-format="auto"
     data-full-width-responsive="true"></ins>
<script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>
  </div>
</MainLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const jwtInput = document.getElementById('jwt-input');
    const statusBar = document.getElementById('status-bar');
    const outputSection = document.getElementById('output-section');
    
    const outHeader = document.getElementById('out-header');
    const outPayload = document.getElementById('out-payload');
    const outSignature = document.getElementById('out-signature');
    const claimsBody = document.getElementById('claims-body');
    
    const btnCopyHeader = document.getElementById('btn-copy-header');
    const btnCopyPayload = document.getElementById('btn-copy-payload');

    let decodedHeader = '';
    let decodedPayload = '';

    function decodeBase64Url(str) {
      let base64 = str.replace(/-/g, '+').replace(/_/g, '/');
      while (base64.length % 4) {
        base64 += '=';
      }
      const binStr = atob(base64);
      const bytes = new Uint8Array(binStr.length);
      for (let i = 0; i < binStr.length; i++) {
        bytes[i] = binStr.charCodeAt(i);
      }
      return new TextDecoder().decode(bytes);
    }

    function formatUnixTime(unixTs) {
      if (!unixTs) return '';
      const date = new Date(unixTs * 1000);
      return date.toLocaleString();
    }

    function isExpired(unixTs) {
      if (!unixTs) return false;
      return (Date.now() / 1000) > unixTs;
    }

    function parseJWT() {
      const token = jwtInput.value.trim();
      if (!token) {
        statusBar.style.display = 'none';
        outputSection.style.display = 'none';
        return;
      }

      try {
        const parts = token.split('.');
        if (parts.length !== 3) {
          throw new Error("Token must have exactly 3 parts separated by dots.");
        }

        const headerStr = decodeBase64Url(parts[0]);
        const payloadStr = decodeBase64Url(parts[1]);
        
        // Validate JSON parsing
        const headerObj = JSON.parse(headerStr);
        const payloadObj = JSON.parse(payloadStr);

        decodedHeader = JSON.stringify(headerObj, null, 2);
        decodedPayload = JSON.stringify(payloadObj, null, 2);

        outHeader.textContent = decodedHeader;
        outPayload.textContent = decodedPayload;
        outSignature.textContent = parts[2];

        // Process Claims Table
        claimsBody.innerHTML = '';
        
        const standardClaims = {
          'iss': 'Issuer',
          'sub': 'Subject',
          'aud': 'Audience',
          'exp': 'Expiration Time',
          'nbf': 'Not Before',
          'iat': 'Issued At',
          'jti': 'JWT ID'
        };

        for (const [key, val] of Object.entries(payloadObj)) {
          const tr = document.createElement('tr');
          const tdKey = document.createElement('td');
          tdKey.style.fontWeight = 'bold';
          tdKey.style.fontFamily = 'monospace';
          tdKey.textContent = key;
          
          const tdVal = document.createElement('td');
          const tdDesc = document.createElement('td');
          
          let valStr = typeof val === 'object' ? JSON.stringify(val) : String(val);
          tdVal.textContent = valStr;
          tdVal.style.fontFamily = 'monospace';
          tdVal.style.wordBreak = 'break-all';

          tdDesc.textContent = standardClaims[key] || 'Custom Claim';

          // Special formatting for dates
          if (['exp', 'iat', 'nbf'].includes(key) && typeof val === 'number') {
             const dateStr = formatUnixTime(val);
             let extra = '';
             if (key === 'exp') {
               if (isExpired(val)) {
                 extra = ' <span class="tag-expired">(EXPIRED)</span>';
               } else {
                 extra = ' <span class="tag-valid">(Valid)</span>';
               }
             }
             tdVal.innerHTML = `${valStr} <br><small style="color:var(--color-text-muted)">${dateStr}</small>${extra}`;
          }

          tr.appendChild(tdKey);
          tr.appendChild(tdVal);
          tr.appendChild(tdDesc);
          claimsBody.appendChild(tr);
        }

        statusBar.className = 'status-indicator status-valid';
        statusBar.textContent = 'Valid JWT Structure ✓';
        statusBar.style.display = 'inline-block';
        outputSection.style.display = 'block';

      } catch (err) {
        statusBar.className = 'status-indicator status-invalid';
        statusBar.textContent = `Invalid JWT Format ✗ (${err.message})`;
        statusBar.style.display = 'inline-block';
        outputSection.style.display = 'none';
      }
    }

    jwtInput.addEventListener('input', parseJWT);

    btnCopyHeader.addEventListener('click', () => {
      navigator.clipboard.writeText(decodedHeader).then(() => {
        if(typeof window.showToast === 'function') window.showToast('Header copied!');
      });
    });

    btnCopyPayload.addEventListener('click', () => {
      navigator.clipboard.writeText(decodedPayload).then(() => {
        if(typeof window.showToast === 'function') window.showToast('Payload copied!');
      });
    });
  });
</script>
